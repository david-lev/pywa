# --- Required for every example ---
WA_PHONE_ID=1234567890
WA_TOKEN=EAAxxxxxxxxxxxxxxxxx

# --- Required for examples that handle incoming updates (01-04, 06-08) ---
WA_VERIFY_TOKEN=pick-any-string-here
WA_APP_ID=1234567890
WA_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
WA_CALLBACK_URL=https://your-tunnel.ngrok.io

# --- Required for templates and flows (04, 05) ---
WA_BUSINESS_ACCOUNT_ID=1234567890

# --- Required for flows only (04) ---
# Generate with:
#   openssl genrsa -aes256 -passout pass:CHANGE_ME -out private.pem 2048
#   openssl rsa -in private.pem -outform PEM -pubout -out public.pem
# Then paste the private key contents below as a single quoted line (escape newlines as \n) or load from a file.
WA_FLOW_PRIVATE_KEY_PATH=./private.pem
WA_FLOW_PRIVATE_KEY_PASSWORD=CHANGE_ME

# --- Recipient used by send-only scripts (05) ---
WA_TEST_RECIPIENT=521234567890
